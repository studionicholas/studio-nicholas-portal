# Netlify cache headers.
# Always revalidate the entry point + service worker so a new deploy is picked
# up on the next load, while content-hashed assets are cached forever.
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
/assets/*
  Cache-Control: public, max-age=31536000, immutable
